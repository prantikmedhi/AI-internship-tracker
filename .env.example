# Telegram Bot Token (Get from https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Notion OAuth Configuration (Get from https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=your_client_id_here
NOTION_CLIENT_SECRET=your_client_secret_here
TELEGRAM_BOT_OAUTH_CALLBACK=http://localhost:3000/api/auth/telegram/callback

# Session security (generate a random 32+ character string)
SESSION_SECRET=your_session_secret_min_32_characters_long

# LLM Configuration
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_API_URL=http://localhost:11434/api/chat
GEMINI_API_KEY=  # Optional: leave empty to skip Gemini
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=ollama  # "ollama" or "gemini"